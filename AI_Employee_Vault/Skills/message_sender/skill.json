{
  "name": "message_sender",
  "version": "2.0.0",
  "description": "Unified message sending for Gmail and WhatsApp with HITL workflow",
  "author": "AI Employee Vault",
  "tier": "gold",
  "type": "automation",
  "platforms": ["gmail", "whatsapp"],
  "capabilities": [
    "email_sending",
    "whatsapp_messaging",
    "persistent_sessions",
    "retry_logic",
    "error_recovery",
    "hitl_workflow"
  ],
  "dependencies": {
    "python": ">=3.8",
    "playwright": ">=1.40.0",
    "google-api-python-client": ">=2.0.0",
    "google-auth-oauthlib": ">=1.0.0"
  },
  "integration": {
    "event_bus": true,
    "audit_logger": true,
    "folder_manager": true,
    "retry_queue": true,
    "skill_registry": true
  },
  "workflow": {
    "input_folder": "/Approved",
    "success_folder": "/Done",
    "failure_folder": "/Failed",
    "session_folder": "/Sessions"
  },
  "execution": {
    "command": "python3 sender.py",
    "timeout": 120000
  }
}
