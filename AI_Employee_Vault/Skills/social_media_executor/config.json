{
  "platforms": {
    "linkedin": {
      "enabled": true,
      "session_dir": "linkedin",
      "selectors": {
        "start_post_button": "[aria-label*='Start a post']",
        "editor": ".ql-editor, [role='textbox']",
        "post_button": "button[type='submit']:has-text('Post')",
        "media_upload": "input[type='file'][accept*='image']"
      },
      "timeouts": {
        "page_load": 30000,
        "button_click": 5000,
        "post_submit": 10000
      }
    },
    "facebook": {
      "enabled": true,
      "session_dir": "facebook",
      "selectors": {
        "create_post": "[aria-label*='Create a post'], [aria-label*='What\\'s on your mind']",
        "editor": "[role='textbox'][contenteditable='true']",
        "next_button": "[aria-label*='Next']",
        "post_button": "[aria-label*='Post'], [aria-label*='Share']",
        "media_upload": "input[type='file'][accept*='image']"
      },
      "timeouts": {
        "page_load": 30000,
        "button_click": 5000,
        "post_submit": 10000
      }
    },
    "instagram": {
      "enabled": true,
      "session_dir": "instagram",
      "selectors": {
        "create_post": "[aria-label*='New post'], [aria-label*='Create']",
        "media_upload": "input[type='file'][accept*='image']",
        "next_button": "button:has-text('Next')",
        "caption_input": "textarea[aria-label*='caption']",
        "share_button": "button:has-text('Share')"
      },
      "timeouts": {
        "page_load": 30000,
        "button_click": 5000,
        "post_submit": 10000
      },
      "requires_media": true
    },
    "twitter": {
      "enabled": true,
      "session_dir": "twitter",
      "selectors": {
        "tweet_button": "[aria-label*='Tweet'], [data-testid='tweetButtonInline']",
        "editor": "[role='textbox'][contenteditable='true']",
        "post_button": "[data-testid='tweetButton']",
        "media_upload": "input[type='file'][accept*='image']"
      },
      "timeouts": {
        "page_load": 30000,
        "button_click": 5000,
        "post_submit": 10000
      },
      "char_limit": 280
    }
  },
  "retry": {
    "max_attempts": 3,
    "initial_delay": 5000,
    "backoff_multiplier": 2
  },
  "browser": {
    "headless": false,
    "viewport": {
      "width": 1280,
      "height": 720
    },
    "user_agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36"
  },
  "logging": {
    "screenshot_on_error": true,
    "verbose": true
  }
}
